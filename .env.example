# ----------------------------------------------------------------------------
# TheWebsiteForge — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# ----------------------------------------------------------------------------

# --- PostgreSQL (used by docker-compose.yml) --------------------------------
POSTGRES_USER=twf
POSTGRES_PASSWORD=change_me_in_dev
POSTGRES_DB=thewebsiteforge
POSTGRES_PORT=5432

# Full connection string used by the app + Drizzle.
# When running the DB via docker-compose locally, host is `localhost`.
# Must line up with the POSTGRES_* values above.
DATABASE_URL=postgresql://twf:change_me_in_dev@localhost:5432/thewebsiteforge

# --- Admin access (allowlist) -----------------------------------------------
# Comma-separated list of Google account emails allowed into /admin.
# Simple bootstrap approach for now — see plan §6.
ADMIN_EMAILS=you@example.com,partner@example.com

# --- Firebase: server (Admin SDK, used to verify ID tokens) -----------------
# From your Firebase service account JSON (Project settings → Service accounts).
# Keep the private key on ONE line, with literal \n for newlines (quotes required).
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...your...key...\n-----END PRIVATE KEY-----\n"

# --- Firebase: client (web SDK, used for Google sign-in) --------------------
# From Firebase Project settings → Your apps → Web app config.
# These are exposed to the browser (safe — they're public client config).
NUXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NUXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# --- Payments: Paystack (PRIMARY — wallet top-ups + one-off builds, see plan §3.1)
# South Africa account → charges/settles in ZAR. Use TEST keys while developing.
# Secret key is SERVER-ONLY — never expose it to the browser.
PAYSTACK_SECRET_KEY=sk_test_xxx
NUXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx
# Note: Paystack webhooks are verified with HMAC-SHA512 of the raw body using
# PAYSTACK_SECRET_KEY — there is no separate webhook signing secret.
# (No Paystack Plans needed — the wallet model uses one-off charges only.)

# Public base URL of the deployed site (no trailing slash). Used to build the
# Paystack checkout callback_url. In local dev it falls back to the request
# origin, so you only strictly need this in production.
NUXT_PUBLIC_SITE_URL=https://websiteforge.pixelatedindustries.com

# USD→ZAR conversion (Option A: display USD, charge ZAR). Keep both in sync —
# the server charges with USD_TO_ZAR; the client shows estimates with the public
# one. Price slightly above spot to absorb FX drift.
USD_TO_ZAR=17
NUXT_PUBLIC_USD_TO_ZAR=17

# --- Payments: deferred fallbacks (only if Paystack doesn't fit, see plan §3.4)
# These are SA-friendly alternatives you could add later if ever needed.
# (Stripe is intentionally omitted — it has no direct SA support; the only path
#  is Stripe Atlas / a US entity, which is out of scope. See plan §3.4.)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PEACH_ENTITY_ID=
PEACH_ACCESS_TOKEN=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# --- Email (Resend — transactional email, see plan §3.2) --------------------
RESEND_API_KEY=re_xxx
MAIL_FROM="Pixelated Industries WebsiteForge <hello@pixelatedindustries.com>"
MAIL_ADMIN=admin@pixelatedindustries.com
# Public-facing support address (used as Reply-To on customer emails).
MAIL_SUPPORT=support@pixelatedindustries.com

# --- Cloudflare (domain management — see plan §9.1) -------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
